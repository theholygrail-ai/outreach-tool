# Groq LLM
GROQ_API_KEY=gsk_...your_groq_api_key...

# Explorium / Vibe Prospecting
EXPLORIUM_API_KEY=your_explorium_api_key

# Optional: Brave Search, Firecrawl, Vercel
BRAVE_API_KEY=
FIRECRAWL_API_KEY=
VERCEL_TOKEN=your_vercel_token

# Google Stitch (for stitch-mcp)
STITCH_API_KEY=your_stitch_api_key

# AWS
AWS_PROFILE=astro-invest
AWS_REGION=us-east-1

# Billing alert email
BILLING_ALERT_EMAIL=your_email@example.com

# Calendly OAuth (+ optional API token for smoke tests)
CALENDLY_CLIENT_ID=
CALENDLY_CLIENT_SECRET=
CALENDLY_WEBHOOK_SECRET=
CALENDLY_ACCESS_TOKEN=
CALENDLY_LINK=https://calendly.com/your-link

# Outreach (SES)
SENDER_EMAIL=your_verified_ses_email@example.com
SES_AWS_ACCESS_KEY_ID=
SES_AWS_SECRET_ACCESS_KEY=
SES_REGION=us-east-1

# Local dev ports (9000+ recommended)
API_PORT=9002
WEB_PORT=9001

# Production: Vite build (set in Vercel) — Lambda Function URL, no trailing slash
# VITE_API_URL=https://xxxx.lambda-url.us-east-1.on.aws

# Optional: shown in Settings when API runs on Lambda
# PUBLIC_API_URL=https://xxxx.lambda-url.us-east-1.on.aws
