# Groq LLM
GROQ_API_KEY=gsk_...your_groq_api_key...

# Explorium / Vibe Prospecting
EXPLORIUM_API_KEY=your_explorium_api_key

# Optional: Brave Search, Firecrawl, Vercel
BRAVE_API_KEY=
FIRECRAWL_API_KEY=
VERCEL_TOKEN=your_vercel_token

# Discovery enrichment + strict list visibility (Pipeline Worker)
# PLAYWRIGHT_ENABLED=1 on Lambda enables browser enrichment (Docker worker image)
PLAYWRIGHT_ENABLED=0
ENRICH_MAX_PAGES=8
STRICT_MIN_QUALITY=45
# Minimum quality to keep a discovery lead (after discovery bonuses). Default 22 — raise if too many weak leads save.
# DISCOVERY_MIN_QUALITY=22
# Discovery merges Explorium + Apollo + Hunter Discover + Bright Data (SERP HTML) + Brave; default POST /api/pipeline/discover limit is 50 (max 100).
STRICT_REQUIRE_CONTACT=1
# email_only = require valid email only | email_plus_alt = (email+phone) OR (email+linkedin)
STRICT_CONTACT_MODE=email_plus_alt
VERIFICATION_MAX_AGE_DAYS=30
# Optional verification providers (low-friction free tiers)
ABSTRACT_API_KEY=
COMPANIES_HOUSE_API_KEY=

# Third-party enrichment + verification (never commit real keys)
# Apollo: https://docs.apollo.io/docs/create-api-key
APOLLO_API_KEY=
# Set to 1 to request personal emails (consumes Apollo credits; GDPR regions may be withheld)
# APOLLO_REVEAL_PERSONAL_EMAILS=1
# Hunter: https://hunter.io/api-keys
HUNTER_API_KEY=
# Bright Data Web Unlocker — same /request API as https://github.com/brightdata/sdk-python (sync mode)
BRIGHTDATA_API_TOKEN=
# Zone name from Bright Data control panel (Web Unlocker product)
BRIGHTDATA_ZONE=
# FORCE_REVERIFY=1  — pipeline stageEnrich re-runs deep enrich + verify
# Groq agent assists (set to 0 to disable)
# ENRICHMENT_AGENT_EMAIL_RANKER=0
# ENRICHMENT_AGENT_INSIGHTS=0

# Google Stitch (for stitch-mcp)
STITCH_API_KEY=your_stitch_api_key

# AWS
AWS_PROFILE=astro-invest
AWS_REGION=us-east-1

# Billing alert email
BILLING_ALERT_EMAIL=your_email@example.com

# Calendly OAuth (+ optional API token for smoke tests)
CALENDLY_CLIENT_ID=
CALENDLY_CLIENT_SECRET=
CALENDLY_WEBHOOK_SECRET=
CALENDLY_ACCESS_TOKEN=
CALENDLY_LINK=https://calendly.com/your-link

# Outreach (SES) — pipeline worker sends email at stage outreach_ready → sent
SENDER_EMAIL=your_verified_ses_email@example.com
SES_AWS_ACCESS_KEY_ID=
SES_AWS_SECRET_ACCESS_KEY=
SES_REGION=us-east-1
# OUTREACH_AUTO_SEND=0  — keep drafts only (no SES)
# OUTREACH_DRY_RUN=1    — advance to sent without calling SES (testing)

# Local dev ports (9000+ recommended)
API_PORT=9002
WEB_PORT=9001

# Production: Vite build (set in Vercel) — Lambda Function URL, no trailing slash
# VITE_API_URL=https://xxxx.lambda-url.us-east-1.on.aws

# Optional: shown in Settings when API runs on Lambda
# PUBLIC_API_URL=https://xxxx.lambda-url.us-east-1.on.aws
